# Server-side environment variables for the /api/state function on Vercel.
# Set these in the Vercel dashboard (Project → Settings → Environment Variables).
# They are NEVER exposed to the browser.

# The shared passphrase you type to unlock the app.
# Set it to "none", "false", or "null" (or leave it unset) to run WITH NO
# passphrase — the app opens directly with no unlock screen.
APP_PASSPHRASE=change-me-to-something-only-you-know

# Upstash Redis (a.k.a. Vercel KV) REST credentials. When you attach an
# Upstash/KV store to the project from the Vercel Storage tab, these two are
# injected automatically — you normally don't set them by hand.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Web Push reminders (optional) ---
# Generate a keypair once with:  npx web-push generate-vapid-keys
# The PUBLIC key goes in two places: VAPID_PUBLIC_KEY (server) and
# VITE_VAPID_PUBLIC_KEY (frontend build — same value). Keep PRIVATE server-only.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY=
# Contact URI required by push services — use your email.
VAPID_SUBJECT=mailto:you@example.com
# Protects the daily /api/cron endpoint. Vercel automatically sends this as a
# Bearer token on scheduled runs when set. Use any long random string.
CRON_SECRET=
